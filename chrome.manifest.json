{
    "manifest_version": 3,
    "name": "sitecite",
    "version": "1.1.0",
    "description": "Quote websites with image previews!",
    "action": {
        "default_popup": "HTML/index.html"
    },
    "icons": {
        "16": "icons/sitecite_16.png",
        "32": "icons/sitecite_32.png",
        "64": "icons/sitecite_64.png",
        "128": "icons/sitecite_128.png",
        "512": "icons/sitecite_512.png"
    },
    "commands": {
        "copy-quote": {
            "suggested_key": {
                "default": "Alt+Shift+C",
                "mac": "Command+MacCtrl+C"
            },
            "description": "Quote selected text"
        },
        "copy-quote-img": {
            "description": "Copy an image of selected text"
        }
    },
    "permissions": [
        "contextMenus",
        "activeTab",
        "scripting",
        "storage",
        "clipboardWrite"
    ],
    "background": {
        "type": "module",
        "service_worker": "JS/background.js"
    },
    "browser_specific_settings": {
        "gecko": {
            "id": "sitecite@dantenl.extension",
            "strict_min_version": "142.0",
            "data_collection_permissions": {
                "required": [
                    "websiteContent"
                ]
            }
        }
    },
    "minimum_chrome_version": "113"
}
